# Supabase — Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Meta Cloud API — developers.facebook.com > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_system_user_token

# Webhook verification — any random secret string you choose
WA_WEBHOOK_VERIFY_TOKEN=your_random_secret

# Upstash Redis — console.upstash.com > your database > Redis URL (rediss://)
UPSTASH_REDIS_URL=rediss://default:[password]@[host]:6380

# App
PORT=8000
APP_ENV=development
APP_BASE_URL=https://your-app-name.onrender.com

# Scheduler — hour and minute in IST (Asia/Kolkata) for APScheduler
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0
